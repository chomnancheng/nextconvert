# Clerk (renderer) — copy to `.env` or `.env.local` for local dev.
# https://clerk.com/docs/react/getting-started/quickstart
VITE_CLERK_PUBLISHABLE_KEY=

# Supabase — required for device restriction via Edge Function.
# Find these in your Supabase project → Settings → API.
# Set CLERK_ISSUER as a Supabase secret: supabase secrets set CLERK_ISSUER=https://your-instance.clerk.accounts.dev
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

{
  "name": "nextconvert",
  "version": "0.1.9",
  "description": "Image to Reels converter desktop app",
  "author": "NextConvert Team",
  "main": "dist/electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:renderer\" \"bun run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && electron .",
    "build": "bun run build:renderer && bun run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:mac": "bun run build && electron-packager . nextconvert --platform=darwin --arch=x64 --out=release/mac --overwrite --no-asar",
    "build:win": "bun run build && electron-packager . nextconvert --platform=win32 --arch=x64 --out=release/win --overwrite --no-asar",
    "build:all": "bun run build:mac && bun run build:win",
    "dist": "bun run build && electron-builder --publish never",
    "dist:mac": "bun run build && electron-builder --mac --publish never",
    "dist:win": "bun run build && electron-builder --win --publish never",
    "dist:all": "bun run build && electron-builder --mac --win --publish never",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint app --ext .ts,.tsx"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/ffmpeg-static": "^5.1.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^41.5.0",
    "electron-builder": "^25.1.8",
    "electron-packager": "^14.2.1",
    "eslint": "^9.16.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}